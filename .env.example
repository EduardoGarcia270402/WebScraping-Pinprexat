# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sercop_db
DB_USER=postgres
DB_PASSWORD=tu_password

# Firecrawl
FIRECRAWL_API_KEY=tu_api_key

# Notificaciones - Email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password
EMAIL_DESTINATARIO=destinatario@gmail.com

# Notificaciones - Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# Activar/desactivar notificaciones
NOTIFICATIONS_ENABLED=false

# Guardar contenido crudo devuelto por Firecrawl para depurar parser
SAVE_RAW_RESPONSES=false

# Descarga de documentos anexos
DOWNLOAD_DOCUMENTS=true
DOCUMENTS_DIR=downloads/documentos_anexos

# Google Drive (opcional)
DRIVE_UPLOAD_ENABLED=false
DRIVE_AUTH_MODE=oauth
DRIVE_SERVICE_ACCOUNT_FILE=credentials/google-drive-service-account.json
DRIVE_OAUTH_CLIENT_FILE=credentials/google-drive-oauth-client.json
DRIVE_OAUTH_TOKEN_FILE=credentials/google-drive-token.json
DRIVE_FOLDER_ID=
DRIVE_FOLDER_NAME=NecesidadesContratacion

# Cotizaciones
QUOTATION_ENABLED=true
QUOTATION_AUTO_GENERATE=false
QUOTATIONS_DIR=downloads/cotizaciones
QUOTATION_REGENERATE_EXISTING=false
QUOTATION_DRIVE_FOLDER_ID=
QUOTATION_DRIVE_FOLDER_NAME=Cotizaciones
COMPANY_NAME=PINPREXAT
COMPANY_RUC=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_LOGO_PATH=assets/logo/pinprexat-logo.jpeg

# Scheduler (horas de ejecucion, formato 24h separadas por coma)
SCHEDULE_HOURS=8,14,20
